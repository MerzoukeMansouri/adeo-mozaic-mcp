# Server Configuration
NODE_ENV=production
PORT=3000

# Authentication
# Generate a secure token: openssl rand -base64 32
AUTH_TOKEN=your-secret-bearer-token-here

# Database
DATABASE_PATH=/app/data/mozaic.db

# MCP Configuration
MCP_DEBUG=false
MCP_SERVER_PATH=/app/dist/index.js

# CORS Origins (comma-separated)
CORS_ORIGINS=https://v0.dev,https://*.v0.dev,https://your-domain.com

# Optional: Dokploy Configuration
DOKPLOY_DOMAIN=mozaic-mcp.yourdomain.com
DOKPLOY_SSL=true